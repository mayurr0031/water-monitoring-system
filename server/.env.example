# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
# If password contains special characters like #, @, !, quote the entire value
# Examples:
#   DB_PASSWORD="Pass@word#123"      (with special chars)
#   DB_PASSWORD=SimplePassword        (no quotes needed for simple passwords)
DB_PASSWORD="your_password_here"
DB_NAME=water_level_monitor

# Tomorrow.io Weather API
# Get your free API key from: https://www.tomorrow.io/
TOMORROW_API_KEY="your_api_key_here"

# Location Coordinates (Latitude, Longitude)
# Default: Delhi, India (28.7041, 77.1025)
LOCATION_LAT=28.7041
LOCATION_LON=77.1025
